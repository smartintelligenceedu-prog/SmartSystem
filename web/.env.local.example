# Copy this file to .env.local and fill in your actual Supabase project values
# (Project Settings -> API in the Supabase dashboard). Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server-only, never exposed to the browser. Used by
# src/lib/supabase/admin.ts for the small set of operations that must bypass
# RLS on purpose (public registration signup, the settle-commissions function).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
